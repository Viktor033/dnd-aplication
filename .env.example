# ==========================================
# DM Engine — Variables de Entorno
# ==========================================
# Copiá este archivo como .env y completá tus datos reales.
# NUNCA subas el .env real a Git.

# Base de datos MySQL
DB_URL=jdbc:mysql://localhost:3306/dm_engine_db?useSSL=false&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=tu_password_aqui

# Spring AI — Anthropic Claude (opcional)
# Si querés usar IA real, cambiá dmengine.ai.provider=anthropic en application.properties
# y completá tu API key de https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
